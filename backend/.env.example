# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/artist-portfolio?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# TOTP secret encryption
TOTP_ENCRYPTION_KEY=another_long_random_secret_for_encrypting_totp_secrets

# Account lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# Rate limiting (window values are in milliseconds)
LOGIN_RATE_LIMIT_WINDOW=900000
LOGIN_RATE_LIMIT_MAX=5
GENERAL_RATE_LIMIT_WINDOW=900000
GENERAL_RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_WINDOW=3600000
UPLOAD_RATE_LIMIT_MAX=50

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Seed Credentials (used only once to seed the DB)
ADMIN_EMAIL=your_admin_email
ADMIN_PASSWORD=your_strong_initial_password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend URL (for security headers in deployed environments)
BACKEND_URL=http://localhost:5000
